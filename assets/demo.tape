# Koda — README demo GIF (Claude Code–style session + /commit)
# Regenerate: vhs assets/demo.tape

Output assets/demo.gif

Set Shell "bash"
Set FontSize 14
Set Width 1100
Set Height 640
Set Theme "Catppuccin Mocha"
Set Padding 24
Set Framerate 30
Set PlaybackSpeed 1.15
Set TypingSpeed 45ms
Set CursorBlink false

Hide
Type "cd $(git rev-parse --show-toplevel 2>/dev/null || pwd) && bash assets/demo-recording.sh"
Enter
Show

Sleep 28s
