{
  "name": "@varunbilluri/koda",
  "version": "0.1.2",
  "description": "Agentic coding tool in your terminal — like Claude Code, free & open source",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "koda": "./bin/koda.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark:kcb10": "tsx benchmarks/kcb-10/runner.ts --mock",
    "benchmark:kcb10:live": "tsx benchmarks/kcb-10/runner.ts --live",
    "serve": "tsx src/index.ts serve",
    "app:desktop": "pnpm build && cd apps/desktop && npm install && npm start",
    "app:desktop:mac": "pnpm build && cd apps/desktop && npm install && npm run pack:mac",
    "app:desktop:win": "pnpm build && cd apps/desktop && npm install && npm run pack:win"
  },
  "keywords": [
    "ai",
    "cli",
    "code-intelligence",
    "developer-tools",
    "autonomous-agent",
    "software-engineer"
  ],
  "author": "Varun Billuri",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/varunbiluri/koda"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "tree-sitter",
      "tree-sitter-typescript",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "esbuild"
    ],
    "overrides": {
      "string-width": "7"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "natural": "^6.12.0",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "tree-sitter": "0.21.1",
    "tree-sitter-python": "0.23.5",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
