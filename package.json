{
  "name": "@varunbilluri/koda",
  "version": "0.1.2",
  "description": "AI software engineer — terminal-based repository intelligence engine",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "koda": "./bin/koda.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "cli",
    "code-intelligence",
    "developer-tools",
    "autonomous-agent",
    "software-engineer"
  ],
  "author": "Varun Billuri",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/varunbiluri/koda"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "tree-sitter",
      "tree-sitter-typescript",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "esbuild"
    ],
    "overrides": {
      "string-width": "7",
      "afinn-165": "1"
    }
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "natural": "^8.1.1",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "tree-sitter": "0.21.1",
    "tree-sitter-python": "0.23.5",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
